# Auth (Clerk)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# AI
GEMINI_API_KEY=

# Memory (Cognee Cloud — get API key from platform.cognee.ai)
COGNEE_API_URL=https://api.cognee.ai
COGNEE_SERVICE_TOKEN=

# Integrations
COMPOSIO_API_KEY=
SERPER_API_KEY=
APOLLO_API_KEY=
# Paid Apollo plan required for people/match enrichment (free plan returns API_INACCESSIBLE 403).
# Create a master key at Settings → Integrations → API Keys with enrichment endpoints enabled.

# In-house email verification (SMTP RCPT check on port 25)
# EMAIL_VERIFIER_HELO_DOMAIN=outpitch.app
# EMAIL_VERIFIER_FROM_EMAIL=verify@outpitch.app
# EMAIL_VERIFIER_SMTP_TIMEOUT_MS=8000

# Data (Neon Postgres + hosted Redis)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/outpitch?sslmode=require
REDIS_URL=redis://default:password@redis-xxx.upstash.io:6379

# API
API_PORT=4000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
