{
  "name": "outpitch",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "npm run generate --workspace=@outpitch/db",
    "db:migrate": "npm run migrate --workspace=@outpitch/db",
    "db:push": "npm run push --workspace=@outpitch/db"
  },
  "devDependencies": {
    "turbo": "2.9.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2"
}
