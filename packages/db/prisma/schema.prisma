generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  clerkId           String   @unique
  email             String?
  name              String?
  cogneeToken       String?
  cogneeUserId      String?
  linkedinConnected Boolean  @default(false)
  gmailConnected    Boolean  @default(false)
  onboardingDone    Boolean  @default(false)
  whatsappNumber     String?  @unique
  whatsappVerified   Boolean  @default(false)
  whatsappVerifyCode String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  profile    UserProfile?
  campaigns  OutreachCampaign[]
  chatMessages ChatMessage[]
  chatSessions ChatSession[]
  companyLinks UserCompanyLink[]
  emailThreads EmailThread[]
}

model UserProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  headline         String?
  summary          String?
  skills           String[] @default([])
  targetRole       String?
  targetLocation   String?
  targetIndustries String[] @default([])
  experienceYears  Int?
  linkedinData     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id              String   @id @default(cuid())
  name            String
  domain          String   @unique
  description     String?
  industry        String?
  employeeCount   String?
  sourceUrl       String?
  cogneeDataset   String?
  crawledAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contacts  CompanyContact[]
  campaigns OutreachCampaign[]
  userLinks UserCompanyLink[]
}

model CompanyContact {
  id         String   @id @default(cuid())
  companyId  String
  name       String
  title      String?
  email      String?
  linkedinUrl String?
  source     String   @default("crawl")
  confidence Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaigns OutreachCampaign[]

  @@index([companyId])
  @@index([email])
}

model UserCompanyLink {
  id          String   @id @default(cuid())
  userId      String
  companyId   String
  matchScore  Int      @default(0)
  feedback    String?
  discoveredAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
}

model OutreachCampaign {
  id          String   @id @default(cuid())
  userId      String
  companyId   String
  contactId   String?
  subject     String?
  body        String?
  status      String   @default("draft")
  sentAt      DateTime?
  gmailMsgId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact CompanyContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  threads EmailThread[]

  @@index([userId])
  @@index([status])
}

model EmailThread {
  id         String   @id @default(cuid())
  userId     String
  campaignId String?
  gmailId    String?
  threadId   String?
  subject    String?
  fromEmail  String?
  toEmail    String?
  snippet    String?
  isReply    Boolean  @default(false)
  receivedAt DateTime?
  createdAt  DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign OutreachCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([threadId])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New chat")
  channel   String   @default("web")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  sessionId String?
  role      String
  content   String
  toolName  String?
  metadata  Json?
  channel   String   @default("web")
  createdAt DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}

model PipelineJob {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("queued")
  progress  Int      @default(0)
  message   String?
  params    Json?
  result    Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}
